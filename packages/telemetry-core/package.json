{
  "name": "@tacko/telemetry-core",
  "version": "1.1.1",
  "description": "Lightweight telemetry client: events, errors, sessions. Framework-agnostic core.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/unjica/telemetry-tracker.git",
    "directory": "packages/telemetry-core"
  },
  "type": "module",
  "main": "dist/index.js",
