{
  "name": "@telemetry-tracker/vite-plugin",
  "version": "1.0.0",
  "description": "Vite plugin to upload source maps to Telemetry Tracker after build.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Telemetry-Tracker/telemetry-tracker.git",
    "directory": "packages/telemetry-vite-plugin"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "telemetry",
    "vite",
    "vite-plugin",
    "source-maps",
    "sourcemap"
  ],
  "peerDependencies": {
    "vite": ">=5"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3",
    "vite": "^7.3.2",
    "vitest": "^3.2.6"
  }
}
