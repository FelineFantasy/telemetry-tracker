# Server-side API base URL (no trailing slash). Required when dashboard and API are on different hosts.
API_URL=http://localhost:3001

# Public dashboard origin (no trailing slash). Used for sitemap, robots, Open Graph, canonical URLs.
# NEXT_PUBLIC_SITE_URL=https://telemetry-tracker.com

# Google Analytics 4 (optional). Loaded only after cookie consent. Defaults to G-VL5GTNNCHH on telemetry-tracker.com.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-VL5GTNNCHH

# Sentry error monitoring (optional). No-op when unset — mirrors API SENTRY_DSN gating.
# Server / edge: SENTRY_DSN=https://…@sentry.io/…
# Browser (same DSN value): NEXT_PUBLIC_SENTRY_DSN=https://…@sentry.io/…

# Legacy local dev only — skips login middleware. Never set on production.
# NEXT_PUBLIC_TELEMETRY_PUBLIC_DASHBOARD=true
