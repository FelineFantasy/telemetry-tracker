# Server-side API base URL (no trailing slash). Required when dashboard and API are on different hosts.
API_URL=http://localhost:3001

# Public dashboard origin (no trailing slash). Used for sitemap, robots, Open Graph, canonical URLs.
# NEXT_PUBLIC_SITE_URL=https://telemetry.tacko.io

# Legacy local dev only — skips login middleware. Never set on production.
# NEXT_PUBLIC_TELEMETRY_PUBLIC_DASHBOARD=true
