# Base URL of the telemetry API (server-side only). Default: http://localhost:3001
API_URL="http://localhost:3001"

# Public URL of this dashboard (no trailing slash). Required in production for sitemap.xml,
# robots.txt sitemap line, and absolute Open Graph / canonical URLs. Example: https://telemetry.example.com
# NEXT_PUBLIC_SITE_URL="https://telemetry.example.com"

# When "true", skip login middleware (legacy / local dev only).
# NEXT_PUBLIC_TELEMETRY_PUBLIC_DASHBOARD="true"
