// Implementation order for multi-tenant ingest (see apps/api/src/routes/ingest.ts):
// 1. Organization  2. Project  3. ApiKey (lifecycle)  4. ingest auth middleware  5. project_id on telemetry rows  6. UsageMonthly metering

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Billing / ownership. Stripe ids optional until billing is wired.
/// Soft-delete: set `deleted_at` instead of removing rows (telemetry/billing history).
model Organization {
  id                   String    @id @default(uuid())
  name                 String
  plan_tier            PlanTier    @default(FREE)
  stripe_customer_id   String?     @unique @map("stripe_customer_id")
  stripe_subscription_id String? @unique @map("stripe_subscription_id")
  /// Mirrors Stripe Subscription.status when synced via webhooks (e.g. active, past_due).
  stripe_subscription_status String? @map("stripe_subscription_status")
  /// Unix period end from Stripe; for support and dashboard copy.
  stripe_current_period_end DateTime? @map("stripe_current_period_end")
  created_at           DateTime    @default(now()) @map("created_at")
  updated_at           DateTime    @updatedAt @map("updated_at")
  deleted_at           DateTime?   @map("deleted_at")
  projects             Project[]
  memberships          OrganizationMembership[]
  invites              OrganizationInvite[]
  audit_events         OrganizationAuditEvent[]
  brief_completed      BriefCompleted[]
  brief_generation_jobs BriefGenerationJob[]

  @@index([deleted_at])
}

/// Org-scoped dashboard audit trail (settings / security MVP).
model OrganizationAuditEvent {
  id              String       @id @default(uuid())
  organization_id String       @map("organization_id")
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  actor_user_id   String?      @map("actor_user_id")
  actor           User?        @relation(fields: [actor_user_id], references: [id], onDelete: SetNull)
  actor_email     String       @map("actor_email")
  action          String
  target          String
  created_at      DateTime     @default(now()) @map("created_at")

  @@index([organization_id, created_at(sort: Desc), id(sort: Desc)])
  @@index([actor_user_id])
}

/// Dashboard user (email + password). Ingest remains API-key only.
model User {
  id             String                     @id @default(uuid())
  email          String                     @unique
  password_hash  String                     @map("password_hash")
  display_name   String?                    @map("display_name")
  avatar_key          String?              @map("avatar_key")
  avatar_content_type String?              @map("avatar_content_type")
  avatar_updated_at   DateTime?            @map("avatar_updated_at")
  notification_preferences Json?            @map("notification_preferences")
  dashboard_preferences    Json?            @map("dashboard_preferences")
  labs_preferences         Json?            @map("labs_preferences")
  created_at     DateTime                   @default(now()) @map("created_at")
  updated_at     DateTime                   @updatedAt @map("updated_at")
  sessions       UserSession[]
  memberships    OrganizationMembership[]
  invites_sent   OrganizationInvite[] @relation("InviteCreatedBy")
  password_reset_tokens PasswordResetToken[]
  notification_reads    NotificationRead[]
  notification_email_logs NotificationEmailLog[]
  audit_events          OrganizationAuditEvent[]
  brief_acknowledgements BriefAcknowledgement[]
}

model NotificationRead {
  user_id          String   @map("user_id")
  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  notification_id  String   @map("notification_id")
  read_at          DateTime @default(now()) @map("read_at")

  @@id([user_id, notification_id])
  @@index([user_id])
}

/// Per-user watermark for workspace briefs. Advanced only via explicit "Mark as read".
model BriefAcknowledgement {
  id                   String   @id @default(uuid())
  user_id              String   @map("user_id")
  user                 User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  project_id           String   @map("project_id")
  project              Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  /// Upper bound of telemetry included in the last acknowledged brief for this project.
  acknowledged_through DateTime @map("acknowledged_through")
  created_at           DateTime @default(now()) @map("created_at")
  updated_at           DateTime @updatedAt @map("updated_at")

  @@unique([user_id, project_id])
  @@index([user_id])
  @@index([project_id])
  @@index([acknowledged_through])
}

/// Durable AI workspace briefs (async generation). Retention pruned separately from stale display.
model BriefCompleted {
  id                      String       @id @default(uuid())
  organization_id         String       @map("organization_id")
  organization            Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  content_hash            String       @map("content_hash")
  presentation_hash       String       @map("presentation_hash")
  response_schema_version String       @map("response_schema_version")
  /// Immutable correlation id for this generation; reused across dashboard polls until a new hash.
  request_id              String       @map("request_id")
  snapshot_hash           String       @map("snapshot_hash")
  brief_json              Json         @map("brief_json")
  completed_at            DateTime     @default(now()) @map("completed_at")
  expires_at              DateTime     @map("expires_at")

  @@unique([organization_id, content_hash, presentation_hash, response_schema_version])
  @@index([organization_id, completed_at(sort: Desc)])
  @@index([expires_at])
}

enum BriefGenerationJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  EXPIRED
  FAILED
}

/// Postgres-backed brief generation queue. No snapshot_json — worker rebuilds from live telemetry.
model BriefGenerationJob {
  id                      String                   @id @default(uuid())
  organization_id         String                   @map("organization_id")
  organization            Organization             @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  content_hash            String                   @map("content_hash")
  presentation_hash       String                   @map("presentation_hash")
  response_schema_version String                   @map("response_schema_version")
  /// Set once at enqueue; never regenerated.
  request_id              String                   @map("request_id")
  /// Snapshot bucket upper bound captured at enqueue for worker hash verification.
  request_until           DateTime                 @map("request_until")
  status                  BriefGenerationJobStatus @default(PENDING)
  attempt_count           Int                      @default(0) @map("attempt_count")
  lease_owner             String?                  @map("lease_owner")
  lease_expires_at        DateTime?                @map("lease_expires_at")
  created_at              DateTime                 @default(now()) @map("created_at")
  updated_at              DateTime                 @updatedAt @map("updated_at")
  completed_at            DateTime?                @map("completed_at")

  @@unique([organization_id, content_hash, presentation_hash, response_schema_version])
  @@index([status, lease_expires_at, created_at])
  @@index([organization_id, created_at(sort: Desc)])
}

model NotificationEmailLog {
  id               String   @id @default(uuid())
  user_id          String   @map("user_id")
  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  notification_key String   @map("notification_key")
  sent_at          DateTime @default(now()) @map("sent_at")

  @@unique([user_id, notification_key])
  @@index([user_id, sent_at])
}

/// Org membership for dashboard authorization.
model OrganizationMembership {
  id              String       @id @default(uuid())
  user_id         String       @map("user_id")
  user            User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization_id String       @map("organization_id")
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  role            OrgRole      @default(VIEWER)
  created_at      DateTime     @default(now()) @map("created_at")

  @@unique([user_id, organization_id])
  @@index([user_id])
  @@index([organization_id])
}

enum OrgRole {
  OWNER
  EDITOR
  VIEWER
}

/// Pending email invite (register or accept with matching email).
model OrganizationInvite {
  id              String       @id @default(uuid())
  organization_id String       @map("organization_id")
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  email           String       @map("email")
  role            OrgRole      @default(VIEWER)
  token           String       @unique @map("token")
  expires_at      DateTime     @map("expires_at")
  invited_by_id   String       @map("invited_by_id")
  invited_by      User         @relation("InviteCreatedBy", fields: [invited_by_id], references: [id], onDelete: Cascade)
  created_at      DateTime     @default(now()) @map("created_at")
  invite_email_sent_token String? @map("invite_email_sent_token")

  @@unique([organization_id, email])
  @@index([organization_id])
  @@index([email])
}

/// Opaque server-side session (cookie value = id).
model UserSession {
  id             String   @id @default(uuid())
  user_id        String   @map("user_id")
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  expires_at     DateTime @map("expires_at")
  user_agent     String?  @map("user_agent")
  device_browser String?  @map("device_browser")
  device_os      String?  @map("device_os")
  created_at     DateTime @default(now()) @map("created_at")

  @@index([user_id])
  @@index([expires_at])
}

/// One-time password reset link (SHA-256 hex digest of the opaque token; raw secret is emailed only).
model PasswordResetToken {
  id         String   @id @default(uuid())
  user_id    String   @map("user_id")
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  token      String   @unique
  expires_at DateTime @map("expires_at")
  created_at DateTime @default(now()) @map("created_at")

  @@index([user_id])
  @@index([expires_at])
}

/// Telemetry namespace: keys, quotas, and usage rollups attach here.
/// Soft-delete: set `deleted_at` instead of removing rows.
model Project {
  id              String         @id @default(uuid())
  organization_id String         @map("organization_id")
  organization    Organization   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  name            String
  slug            String
  created_at      DateTime       @default(now()) @map("created_at")
  updated_at      DateTime       @updatedAt @map("updated_at")
  deleted_at      DateTime?      @map("deleted_at")
  api_keys        ApiKey[]
  usage_monthly   UsageMonthly[]
  events          Event[]
  sessions        Session[]
  error_groups    ErrorGroup[]
  alert_settings  Json?          @map("alert_settings")
  /// Project deny-list keys for ingest PII scrubbing (see docs/PII-SCRUBBING.md).
  pii_scrub_settings Json?       @map("pii_scrub_settings")
  alert_events    AlertEvent[]
  alert_rules     AlertRule[]
  webhooks        ProjectWebhook[]
  webhook_deliveries AlertWebhookDelivery[]
  source_map_artifacts SourceMapArtifact[]
  brief_acknowledgements BriefAcknowledgement[]

  @@unique([organization_id, slug])
  @@index([organization_id])
  @@index([deleted_at])
}

/// Ingest credential (manageable object, not only a secret).
/// Key format: `tt_live_<publicId>_<secret>` (see docs/ENTITLEMENTS.md).
model ApiKey {
  id           String    @id @default(uuid())
  project_id   String    @map("project_id")
  project      Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  /// User-visible label (e.g. "CI", "Production web").
  name         String?
  /// Random id embedded in the key (lookup before constant-time secret verify).
  public_id    String    @unique @map("public_id")
  /// SHA-256 hex of `publicId + ":" + secret` (secret is the suffix after the last `_`).
  secret_hash  String    @map("secret_hash")
  created_at   DateTime  @default(now()) @map("created_at")
  /// Explicit invalidation; prefer this over soft-delete when rotating secrets.
  revoked_at   DateTime? @map("revoked_at")
  /// Updated on successful ingest auth (optional; rate-limit updates if high traffic).
  last_used_at DateTime? @map("last_used_at")
  /// Optional future expiry; null means no expiry. Ingest rejects after this instant.
  expires_at   DateTime? @map("expires_at")
  /// Soft-delete: hide from UI and reject ingest; keeps audit/history.
  deleted_at   DateTime? @map("deleted_at")
  /// If set, ingest `app` must match this string for this key.
  allowed_app  String?   @map("allowed_app")

  @@index([project_id])
  @@index([deleted_at])
}

/// Monthly meter for quota enforcement (ingest units).
model UsageMonthly {
  id            String   @id @default(uuid())
  project_id    String   @map("project_id")
  project       Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  /// Calendar month `YYYY-MM` (UTC).
  year_month    String   @map("year_month")
  ingest_units  Int      @default(0) @map("ingest_units")
  updated_at    DateTime @updatedAt @map("updated_at")

  @@unique([project_id, year_month])
  @@index([year_month])
}

enum PlanTier {
  FREE
  PRO
  BUSINESS
}

enum AlertRuleType {
  ERROR_SPIKE
  QUOTA_NEAR
  QUOTA_EXCEEDED
  /// Configurable AlertRule row (#493).
  ALERT_RULE
}

/// Extensible condition kinds for AlertRule. Examples only — add values as evaluators ship.
enum AlertConditionType {
  /// Error occurrence count in a rolling window (optional environment scope).
  ERROR_COUNT
}

/// Configurable alert rule (#493). Built-in spike/quota settings remain on Project.alert_settings.
model AlertRule {
  id               String             @id @default(uuid())
  project_id       String             @map("project_id")
  project          Project            @relation(fields: [project_id], references: [id], onDelete: Cascade)
  name             String
  enabled          Boolean            @default(true)
  condition_type   AlertConditionType @map("condition_type")
  /// Condition params (shape depends on condition_type). ERROR_COUNT: threshold, windowMinutes, environment?
  condition        Json
  /// Delivery binding: { email: boolean, webhookIds: string[] } — webhook ids must belong to this project.
  destinations     Json
  /// Rate limit: at most one fire per cooldown bucket (dedupe key).
  cooldown_minutes Int                @default(15) @map("cooldown_minutes")
  created_at       DateTime           @default(now()) @map("created_at")
  updated_at       DateTime           @updatedAt @map("updated_at")
  deleted_at       DateTime?          @map("deleted_at")

  @@index([project_id, enabled])
  @@index([project_id, deleted_at])
}

model AlertEvent {
  id          String        @id @default(uuid())
  project_id  String        @map("project_id")
  project     Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  rule        AlertRuleType
  title       String
  body        String
  href        String?
  dedupe_key  String        @map("dedupe_key")
  fired_at    DateTime      @default(now()) @map("fired_at")
  webhook_deliveries AlertWebhookDelivery[]

  @@unique([project_id, dedupe_key])
  @@index([project_id, fired_at])
}

/// Outbound HTTPS webhook destination for project alert events (#225).
/// Destination format for outbound alert deliveries (#225 generic; #223/#224/#500 chat).
enum AlertWebhookProvider {
  GENERIC
  SLACK
  DISCORD
  MICROSOFT_TEAMS
  TELEGRAM
}

model ProjectWebhook {
  id              String               @id @default(uuid())
  project_id      String               @map("project_id")
  project         Project              @relation(fields: [project_id], references: [id], onDelete: Cascade)
  /// HTTPS URL (validated on write). May contain a provider-issued secret path segment.
  url             String
  /// Delivery payload format / first-party channel (#223 Slack, #224 Discord, #500 Teams/Telegram).
  provider        AlertWebhookProvider @default(GENERIC)
  /// Provider-specific non-secret config (e.g. Telegram `chatId`). Secrets stay in `url`.
  config          Json?
  /// Optional HMAC-SHA256 signing secret (plaintext; protect DB access). Null = unsigned.
  /// Chat providers (Slack/Discord/Teams/Telegram) typically leave this null.
  signing_secret  String?              @map("signing_secret")
  label           String?
  enabled         Boolean              @default(true)
  created_at      DateTime             @default(now()) @map("created_at")
  updated_at      DateTime             @updatedAt @map("updated_at")
  deleted_at      DateTime?            @map("deleted_at")
  deliveries      AlertWebhookDelivery[]

  @@index([project_id, enabled])
  @@index([project_id, deleted_at])
  @@index([project_id, provider, enabled])
}

enum AlertWebhookDeliveryStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  DEAD
}

/// Durable outbound alert webhook delivery queue + attempt / dead-letter log (#225).
/// Enqueued as PENDING before fireProjectAlert returns; claimed by alert-webhook-worker.
model AlertWebhookDelivery {
  id               String                     @id @default(uuid())
  webhook_id       String                     @map("webhook_id")
  webhook          ProjectWebhook             @relation(fields: [webhook_id], references: [id], onDelete: Cascade)
  project_id       String                     @map("project_id")
  project          Project                    @relation(fields: [project_id], references: [id], onDelete: Cascade)
  alert_event_id   String?                    @map("alert_event_id")
  alert_event      AlertEvent?                @relation(fields: [alert_event_id], references: [id], onDelete: SetNull)
  dedupe_key       String                     @map("dedupe_key")
  /// Delivery attempts so far (0 while PENDING before first claim).
  attempt          Int                        @default(0)
  status           AlertWebhookDeliveryStatus @default(PENDING)
  http_status      Int?                       @map("http_status")
  error            String?
  lease_owner      String?                    @map("lease_owner")
  lease_expires_at DateTime?                  @map("lease_expires_at")
  next_attempt_at  DateTime                   @default(now()) @map("next_attempt_at")
  created_at       DateTime                   @default(now()) @map("created_at")
  updated_at       DateTime                   @updatedAt @map("updated_at")

  @@index([webhook_id, created_at])
  @@index([project_id, created_at])
  @@index([dedupe_key])
  @@index([status, next_attempt_at, lease_expires_at])
}

model Event {
  id           String   @id @default(uuid())
  project_id   String   @map("project_id")
  project      Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  app          String
  platform     String?
  environment  String?
  release      String?
  name         String
  user_id      String?
  session_id   String?
  anonymous_id String?
  sdk_version  String?
  properties   Json?
  created_at   DateTime @default(now()) @map("created_at")

  @@index([project_id, created_at])
  @@index([project_id, app])
  @@index([project_id, environment])
}

model ErrorGroup {
  id           String    @id @default(uuid())
  project_id   String    @map("project_id")
  project      Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  fingerprint  String
  message      String
  top_stack    String?
  app          String
  environment  String?
  release      String?
  platform     String?
  occurrences  Int       @default(1)
  first_seen   DateTime  @default(now()) @map("first_seen")
  last_seen    DateTime  @default(now()) @map("last_seen")
  resolved_at  DateTime? @map("resolved_at")
  occurrences_list ErrorOccurrence[]

  @@unique([project_id, fingerprint])
  @@index([project_id, last_seen])
  @@index([project_id, app])
  @@index([project_id, environment])
  @@index([project_id, release])
  @@index([project_id, platform])
}

model ErrorOccurrence {
  id             String     @id @default(uuid())
  error_group_id String     @map("error_group_id")
  error_group    ErrorGroup @relation(fields: [error_group_id], references: [id], onDelete: Cascade)
  stack          String?
  release        String?
  platform       String?
  context        Json?
  session_id     String?
  user_id        String?
  anonymous_id   String?
  sdk_version    String?
  created_at     DateTime   @default(now()) @map("created_at")

  @@index([error_group_id, created_at])
  @@index([error_group_id, platform])
  @@index([error_group_id, release])
}

model Session {
  id             String    @id @default(uuid())
  project_id     String    @map("project_id")
  project        Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  session_id     String    @map("session_id")
  app            String
  platform       String?
  environment    String?
  release        String?
  user_id        String?
  anonymous_id   String?
  user_email     String?   @map("user_email")
  country        String?
  device_browser String?   @map("device_browser")
  device_os      String?   @map("device_os")
  sdk_version    String?
  started_at     DateTime  @default(now()) @map("started_at")
  ended_at       DateTime? @map("ended_at")

  @@index([project_id, started_at])
  @@index([project_id, app])
  @@index([project_id, country])
  @@index([project_id, environment])
  @@index([project_id, release])
}

/// Release / product-update mailing list (marketing site subscribe + registration opt-in).
model MarketingSubscriber {
  id                String                    @id @default(uuid())
  email             String                    @unique
  source            MarketingSubscriberSource
  subscribed_at     DateTime                  @default(now()) @map("subscribed_at")
  unsubscribed_at   DateTime?                 @map("unsubscribed_at")
  /// When the subscriber last gave or renewed marketing consent (GDPR).
  consent_at        DateTime                  @map("consent_at")
  consent_metadata  Json?                     @map("consent_metadata")
  /// SHA-256 hex of opaque one-click unsubscribe token (raw secret emailed only).
  unsubscribe_token String                    @unique @map("unsubscribe_token")
  release_email_sends MarketingReleaseEmailSend[]

  @@index([unsubscribed_at])
  @@index([source])
}

/// Idempotent audit of product update emails delivered per release version.
model MarketingReleaseEmailSend {
  id              String              @id @default(uuid())
  subscriber_id   String              @map("subscriber_id")
  subscriber      MarketingSubscriber @relation(fields: [subscriber_id], references: [id], onDelete: Cascade)
  release_version String              @map("release_version")
  sent_at         DateTime            @default(now()) @map("sent_at")

  @@unique([subscriber_id, release_version])
  @@index([release_version])
}

enum MarketingSubscriberSource {
  subscribe_form
  registration
}

/// Uploaded source map JSON keyed by release and minified bundle path (symbolication in phase 4).
model SourceMapArtifact {
  id           String   @id @default(uuid())
  project_id   String   @map("project_id")
  project      Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  app          String
  release      String
  /// Minified bundle URL or path the map applies to (e.g. https://cdn.example/app.js).
  bundle_url   String   @map("bundle_url")
  /// Raw source map JSON (self-hosted storage; object-store key reserved for later).
  content      String   @db.Text
  storage_key  String?  @map("storage_key")
  sha256       String
  size_bytes   Int      @map("size_bytes")
  uploaded_at  DateTime @default(now()) @map("uploaded_at")

  @@unique([project_id, app, release, bundle_url])
  @@index([project_id, release])
  @@index([project_id, uploaded_at])
}
