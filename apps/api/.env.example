DATABASE_URL=postgresql://postgres:postgres@localhost:5432/telemetry
PORT=3001

# Dashboard auth: allow POST /api/auth/register when at least one user already exists.
# The first user row is always allowed (empty DB). Self-serve signups get no org until they create one or use an invite.
# TELEMETRY_ALLOW_REGISTRATION="true"
#
# Legacy default org UUID for unauthenticated GET /api/meta/projects only — not used to assign new users to an org.
# TELEMETRY_ALLOW_UNAUTHENTICATED_READS="true"  # production only: allow GET /api/* without session (legacy; omit in prod)

# Production / ops (see DEPLOYMENT.md): CORS_ORIGINS, DASHBOARD_ORIGIN, SENTRY_DSN, HEALTH_CHECK_DATABASE,
# RATE_LIMIT_*, TELEMETRY_DASHBOARD_ORIGIN, STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, …
