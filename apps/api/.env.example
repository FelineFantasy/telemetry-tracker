DATABASE_URL=postgresql://postgres:postgres@localhost:5432/telemetry
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# --- Production (Railway / VPS) ---
# NODE_ENV=production
# HEALTH_CHECK_DATABASE=true
# HEALTH_DETAILED=true
# TELEMETRY_API_VERSION=1.6.2  # optional override; build sets version from CHANGELOG
# CORS_ORIGINS=https://telemetry-tracker.com
# TELEMETRY_DASHBOARD_ORIGIN=https://telemetry-tracker.com
# INGEST_ALLOW_UNAUTHENTICATED=false

# Dashboard auth
# TELEMETRY_ALLOW_REGISTRATION=true
# TELEMETRY_ALLOW_UNAUTHENTICATED_READS=true  # legacy only; omit in production

# Stripe billing + webhooks (API only — never on dashboard)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_BUSINESS=price_...

# Optional email (invites + password reset + notifications + contact)
# RESEND_API_KEY=re_...
# TELEMETRY_EMAIL_FROM=Telemetry Tracker <noreply@tacko.io>
# CONTACT_INBOX_EMAIL=info@tacko.io

# Optional observability / tuning
# SENTRY_DSN=
# RATE_LIMIT_INGEST_MAX=3000
# RATE_LIMIT_AUTH_MAX=30
# RATE_LIMIT_API_MAX=300

# Avatar storage (Cloudflare R2 — S3-compatible, private bucket)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=telemetry-avatars
