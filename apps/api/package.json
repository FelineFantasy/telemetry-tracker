{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/generate-api-version.cjs && tsx watch src/index.ts",
    "build": "node scripts/generate-api-version.cjs && prisma generate && tsc -p tsconfig.build.json",
    "postinstall": "node scripts/generate-api-version.cjs && prisma generate",
    "start": "node dist/index.js",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "NODE_ENV=test vitest",
    "retention": "tsx src/jobs/run-retention.ts",
    "alert-rules-evaluator": "tsx src/jobs/run-alert-rules-evaluator.ts",
    "builtin-alert-rules-backfill": "tsx src/jobs/run-builtin-alert-rules-backfill.ts",
    "pii-scrub-backfill": "tsx src/jobs/run-pii-scrub-backfill.ts",
    "brief-worker": "tsx src/jobs/run-brief-worker.ts",
    "alert-webhook-worker": "tsx src/jobs/run-alert-webhook-worker.ts",
    "seed:dev-api-key": "tsx scripts/seed-dev-api-key.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@jridgewell/trace-mapping": "^0.3.31",
    "@prisma/client": "^6.1.0",
    "@sentry/node": "^10.66.0",
    "fastify": "^5.8.5",
    "stripe": "^22.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  }
}
